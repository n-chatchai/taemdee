# PostgreSQL connection string
# Example local dev:
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/taemdee

# JWT signing key for session cookies. Generate a long random string:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-long-random-string

# "development" or "production". Controls cookie Secure flag and SMS sending.
ENVIRONMENT=development

# LINE Login — get these from https://developers.line.biz/console/
# Leave empty to disable the LINE button (returns 503).
# In LINE Developers Console, set the "Callback URL" to match LINE_REDIRECT_URI exactly.
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=http://localhost:8000/auth/line/callback
