# PostgreSQL connection string
# Example local dev:
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/taemdee

# JWT signing key for session cookies. Generate a long random string:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-long-random-string

# "development" or "production". Controls cookie Secure flag and SMS sending.
ENVIRONMENT=development

# Domain name for the platform (e.g., taemdee.com). 
# Subdomains (shop.*) and Redirect URIs are automatically derived from this.
DOMAIN_NAME=taemdee.com

# LINE Login — get these from https://developers.line.biz/console/
# Leave empty to disable the LINE button (returns 503).
# In LINE Developers Console, the "Callback URL" must be: https://<DOMAIN_NAME>/auth/line/callback
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# Google OAuth — Google Cloud Console → APIs & Services → Credentials.
# Leave empty to disable the Google button (returns 503).
# "Authorized redirect URIs" must be: https://<DOMAIN_NAME>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook Login — Meta for Developers → My Apps → Settings → Basic.
# Leave empty to disable the Facebook button (returns 503).
# "Valid OAuth Redirect URIs" must be: https://<DOMAIN_NAME>/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# How many "ลูกค้าล่าสุด" rows the dashboard dock keeps visible. Default 3.
SHOP_CUSTOMER_LAST_SCAN_DISPLAY_NUMBER=3

# Cloudflare R2 — leave R2_ENDPOINT_URL empty to disable image uploads
# (logo + reward image).
# R2_ENDPOINT_URL = S3 API host, used by boto3 for PUTs only.
# R2_PUBLIC_URL   = browser-facing host (R2.dev subdomain or custom
#                   domain) used to build the URL stored in the DB.
#                   Without it, uploaded URLs won't render — the API
#                   host rejects unsigned browser GETs.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=taemdee
R2_PUBLIC_URL=  # e.g. https://pub-xxxx.r2.dev or https://assets.taemdee.com
